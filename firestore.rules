rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - bio: string (optional)
    //   - coins: number (required, default 0)
    //   - role: string (required, 'user' or 'creator')
    //   - createdAt: timestamp (required)
    //
    // Collection: lives
    // Document ID: {liveId}
    // Fields:
    //   - creatorId: string (required)
    //   - creatorName: string (required)
    //   - title: string (required)
    //   - price: number (required)
    //   - status: string (required, 'online' or 'offline')
    //   - viewerCount: number (required)
    //   - startedAt: timestamp (required)
    //
    // Collection: transactions
    // Document ID: {transactionId}
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - type: string (required, 'purchase', 'entry', 'gift', 'window')
    //   - status: string (required, 'pending', 'completed', 'failed')
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isBootstrapAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "robsonbatista3@gmail.com" ||
         request.auth.token.email == "robson0441@gmail.com");
    }

    function isAdmin() {
      return isBootstrapAdmin() || 
        (isAuthenticated() && 
         exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'coins', 'role', 'createdAt']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.coins is number &&
             data.role in ['user', 'creator', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidLive(data) {
      return data.keys().hasAll(['creatorId', 'creatorName', 'title', 'price', 'status', 'viewerCount', 'startedAt']) &&
             data.creatorId is string &&
             data.creatorName is string &&
             data.title is string && data.title.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.status in ['online', 'offline'] &&
             data.viewerCount is number &&
             data.startedAt is timestamp;
    }

    function isValidFollower(data) {
      return data.keys().hasAll(['followerId', 'followedId', 'createdAt']) &&
             data.followerId is string &&
             data.followedId is string &&
             data.createdAt is timestamp;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'message', 'read', 'createdAt']) &&
             data.userId is string &&
             data.type in ['follower', 'gift', 'system'] &&
             data.title is string && data.title.size() < 100 &&
             data.message is string && data.message.size() < 500 &&
             data.read is bool &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Public info is allowed for all.
      allow get: if isAuthenticated();
      allow list: if isAdmin();

      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role != 'admin';
      
      allow update: if isOwner(userId) && 
                      request.resource.data.role == resource.data.role && 
                      request.resource.data.uid == resource.data.uid && 
                      request.resource.data.coins == resource.data.coins;
      
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    match /lives/{liveId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                      (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'creator' || isAdmin()) &&
                      isValidLive(request.resource.data) &&
                      request.resource.data.creatorId == request.auth.uid;
      
      allow update: if isAuthenticated() && 
                      (resource.data.creatorId == request.auth.uid || isAdmin() || 
                       (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slots', 'viewerCount', 'maxWindows'])));
      
      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }
    }

    match /transactions/{transactionId} {
      allow get: if isOwner(resource.data.userId) || isAdmin();
      allow list: if isAdmin() || (isAuthenticated() && request.query.limit <= 100 && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /creator_applications/{applicationId} {
      allow get: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow list: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /followers/{followerId_followedId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid && isValidFollower(request.resource.data);
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isOwner(resource.data.userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
